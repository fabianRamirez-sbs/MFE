# =============================================================================
# PRODUCCIÓN
# Ejecutar con: nx build <app>   (Vite usa --mode=production por defecto en build)
# =============================================================================

VITE_APP_ENV=production
VITE_APP_VERSION=0.0.1

# Mock de autenticación DESACTIVADO — nunca activar fuera de development
VITE_AUTH_MOCK_ENABLED=false

# Stratio — credenciales para generación de tokens (STRATIO_USER / STRATIO_PASSWORD)
VITE_STRATIO_USER=sbs
VITE_STRATIO_PASSWORD=cr<83<P7EMtcf

# Keycloak de producción — SipaNew PROD_ENV
VITE_KEYCLOAK_URL=https://web.sbseguros.co/auth
VITE_KEYCLOAK_REALM=escritorio-virtual
VITE_KEYCLOAK_CLIENT_ID=SIPA-NEW
VITE_KEYCLOAK_LOGOUT_REDIRECT_URI=https://syli.sbseguros.co/sipaNew/

# APIs de producción
VITE_API_CORE_URL=https://api.sipabanca.com/core
VITE_API_ACCOUNTS_URL=https://api.sipabanca.com/accounts
VITE_API_TRANSFERS_URL=https://api.sipabanca.com/transfers
VITE_API_NOTIFICATIONS_URL=https://api.sipabanca.com/notifications

# APIs heredadas SipaNew — producción (migradas desde prod.env.js)
VITE_API_INTEGRATION_URL=https://syli.sbseguros.co/api-int
VITE_API_MODYO_URL=https://integracion.sbseguros.co
VITE_API_DICTIONARIES_URL=https://syli.sbseguros.co/api-biz
VITE_API_STRATIO_AUTH_URL=https://syli.sbseguros.co/api-auth
VITE_API_REPORTS_URL=https://syli.sbseguros.co/api-rpt
VITE_API_DAAS_DICTIONARY_URL=https://syli.sbseguros.co/api-dict
VITE_API_FILE_PROCESSING_URL=https://syli.sbseguros.co/sbs-api-fileProcessing
VITE_API_SIPA_URL=https://syli.sbseguros.co/api-sipa
VITE_API_WEB_URL=https://syli.sbseguros.co/api-web
VITE_API_CERTIFIER_URL=https://syli.sbseguros.co/sbs-api-certifier
VITE_API_CERTIFIER_SBS_URL=https://syli.sbseguros.co/sbs-api-certifier

# MFEs en CDN de producción
VITE_MFE_DASHBOARD_URL=https://cdn.sipabanca.com/mfe-dashboard/remoteEntry.js
VITE_MFE_ACCOUNTS_URL=https://cdn.sipabanca.com/mfe-accounts/remoteEntry.js
VITE_MFE_TRANSFERS_URL=https://cdn.sipabanca.com/mfe-transfers/remoteEntry.js
VITE_MFE_LEGACY_URL=https://cdn.sipabanca.com/mfe-legacy/remoteEntry.js
VITE_MFE_LEGACY_BASE_URL=https://legacy.sipabanca.com
VITE_MFE_SIPA_NEW_BASE_URL=https://syli.sbseguros.co/sipaNew

VITE_HTTP_TIMEOUT_MS=15000
