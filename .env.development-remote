# =============================================================================
# DESARROLLO REMOTO (apunta a servidores devsyli — equivalente a dev-pre.env.js)
# Ejecutar con: nx serve <app> --configuration=development-remote
#
# Usar cuando necesitas probar contra el backend de certificación
# sin levantar servicios localmente.
# =============================================================================

VITE_APP_ENV=development
VITE_APP_VERSION=0.0.1-remote

# Mock de autenticación DESACTIVADO — se usa Keycloak real de certificación
VITE_AUTH_MOCK_ENABLED=false
VITE_AUTH_MOCK_USER_ID=
VITE_AUTH_MOCK_USERNAME=
VITE_AUTH_MOCK_EMAIL=
VITE_AUTH_MOCK_FULL_NAME=
VITE_AUTH_MOCK_ROLES=
VITE_AUTH_MOCK_TOKEN=

# Stratio — credenciales para generación de tokens (STRATIO_USER / STRATIO_PASSWORD)
VITE_STRATIO_USER=test
VITE_STRATIO_PASSWORD=123456

# Usuario de prueba para datos precargados (DEVELOP_DATUSER_*)
VITE_DEV_DATUSER_USER=Fabian Ramirez Alba
VITE_DEV_DATUSER_EMAIL=fabian.ramirez@sbseguros.co

# Keycloak de certificación (mismo que .env.certification)
VITE_KEYCLOAK_URL=https://sbs-sso.modyo.be/auth
VITE_KEYCLOAK_REALM=escritorio-virtual
VITE_KEYCLOAK_CLIENT_ID=SIPA-NEW
VITE_KEYCLOAK_LOGOUT_REDIRECT_URI=https://devsyli.sbseguros.co/sipaNew/

# APIs nuevas MFE — apuntan a certificación
VITE_API_CORE_URL=https://api.cert.sipabanca.com/core
VITE_API_ACCOUNTS_URL=https://api.cert.sipabanca.com/accounts
VITE_API_TRANSFERS_URL=https://api.cert.sipabanca.com/transfers
VITE_API_NOTIFICATIONS_URL=https://api.cert.sipabanca.com/notifications

# APIs heredadas SipaNew — remotas devsyli (dev-pre.env.js)
VITE_API_INTEGRATION_URL=https://devsyli.sbseguros.co/api-int
VITE_API_MODYO_URL=https://sbs-integracion.modyo.be
VITE_API_DICTIONARIES_URL=https://devsyli.sbseguros.co/api-biz
VITE_API_STRATIO_AUTH_URL=https://devsyli.sbseguros.co/api-auth
VITE_API_REPORTS_URL=https://devsyli.sbseguros.co/api-rpt
VITE_API_DAAS_DICTIONARY_URL=https://devsyli.sbseguros.co/api-dict
VITE_API_FILE_PROCESSING_URL=https://devsyli.sbseguros.co/sbs-api-fileProcessing
VITE_API_SIPA_URL=https://devsyli.sbseguros.co/api-sipa
VITE_API_WEB_URL=https://devsyli.sbseguros.co/api-web
VITE_API_CERTIFIER_URL=https://devsyli.sbseguros.co/sbs-api-certifier
VITE_API_CERTIFIER_SBS_URL=http://sbs-api-certifier-pre.sbseguros.tech

# MFEs en localhost — el desarrollador sigue corriendo los MFEs localmente
VITE_MFE_DASHBOARD_URL=http://localhost:3002/assets/remoteEntry.js
VITE_MFE_ACCOUNTS_URL=http://localhost:3003/assets/remoteEntry.js
VITE_MFE_TRANSFERS_URL=http://localhost:3004/assets/remoteEntry.js
VITE_MFE_LEGACY_URL=http://localhost:3005/assets/remoteEntry.js
VITE_MFE_LEGACY_BASE_URL=http://localhost:3005

VITE_HTTP_TIMEOUT_MS=30000
