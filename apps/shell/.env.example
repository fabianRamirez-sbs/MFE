# Variables de entorno del Shell
# Copiar a .env.local y configurar según el entorno

# Keycloak
VITE_KEYCLOAK_URL=http://localhost:8080/auth
VITE_KEYCLOAK_REALM=sipabanca
VITE_KEYCLOAK_CLIENT_ID=shell-spa

# URLs de los MFEs (en producción apuntan al CDN)
VITE_MFE_DASHBOARD_URL=http://localhost:3001/assets/remoteEntry.js
VITE_MFE_ACCOUNTS_URL=http://localhost:3002/assets/remoteEntry.js
VITE_MFE_TRANSFERS_URL=http://localhost:3003/assets/remoteEntry.js
VITE_MFE_LEGACY_URL=http://localhost:3004/assets/remoteEntry.js
VITE_MFE_LEGACY_BASE_URL=http://localhost:3004
