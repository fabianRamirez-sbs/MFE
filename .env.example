# =============================================================================
# SipaBanca MFE — Variables de entorno GLOBALES
# =============================================================================
# Copiar este archivo a:
#   .env.development   → desarrollo local
#   .env.certification → ambiente de certificación (QA)
#   .env.production    → producción
#
# NUNCA commitear archivos .env con valores reales.
# Este .env.example es la única plantilla que va al repositorio.
# =============================================================================

# ─── Modo de operación ────────────────────────────────────────────────────────
VITE_APP_ENV=development        # development | certification | production
VITE_APP_VERSION=0.0.1

# ─── Autenticación Mock (SOLO desarrollo local) ───────────────────────────────
# Poner en true para saltear Keycloak y usar el usuario definido abajo.
# NUNCA activar en certification ni production.
VITE_AUTH_MOCK_ENABLED=false
VITE_AUTH_MOCK_USER_ID=
VITE_AUTH_MOCK_USERNAME=
VITE_AUTH_MOCK_EMAIL=
VITE_AUTH_MOCK_FULL_NAME=
# Lista de roles separados por coma: user,admin,transfers
VITE_AUTH_MOCK_ROLES=
# Token ficticio que se inyectará en las cabeceras Authorization
VITE_AUTH_MOCK_TOKEN=mock-dev-token

# ─── Keycloak ─────────────────────────────────────────────────────────────────
VITE_KEYCLOAK_URL=
VITE_KEYCLOAK_REALM=sipabanca
VITE_KEYCLOAK_CLIENT_ID=shell-spa

# ─── APIs de Backend ──────────────────────────────────────────────────────────
# Cada clave corresponde a un microservicio backend.
# Los MFEs consumen estas URLs via createHttpClient(API.accounts) — ver shared-http.

VITE_API_CORE_URL=              # Core bancario: autenticación, usuario, permisos
VITE_API_ACCOUNTS_URL=          # Servicio de cuentas y saldos
VITE_API_TRANSFERS_URL=         # Servicio de transferencias
VITE_API_NOTIFICATIONS_URL=     # Servicio de notificaciones / alertas

# ─── URLs de los MFEs remotos (Module Federation) ────────────────────────────
# En desarrollo apuntan a localhost. En producción al CDN.

VITE_MFE_DASHBOARD_URL=
VITE_MFE_ACCOUNTS_URL=
VITE_MFE_TRANSFERS_URL=
VITE_MFE_LEGACY_URL=
VITE_MFE_LEGACY_BASE_URL=       # Base URL para el iframe del legacy

# ─── Configuración global de HTTP ─────────────────────────────────────────────
VITE_HTTP_TIMEOUT_MS=15000      # Timeout en milisegundos para todas las llamadas
