# =============================================================================
# SipaBanca MFE — Variables de entorno GLOBALES
# =============================================================================
# Copiar este archivo a:
#   .env.development        → desarrollo local (APIs en localhost)
#   .env.development-remote → desarrollo apuntando a servidores devsyli
#                             (nx serve <app> --configuration=development-remote)
#   .env.certification      → ambiente de certificación (QA)
#   .env.production         → producción
#
# NUNCA commitear archivos .env con valores reales.
# Este .env.example es la única plantilla que va al repositorio.
# =============================================================================

# ─── Modo de operación ────────────────────────────────────────────────────────
VITE_APP_ENV=development        # development | certification | production
VITE_APP_VERSION=0.0.1

# ─── Autenticación Mock (SOLO desarrollo local) ───────────────────────────────
# Poner en true para saltear Keycloak y usar el usuario definido abajo.
# NUNCA activar en certification ni production.
VITE_AUTH_MOCK_ENABLED=false
VITE_AUTH_MOCK_USER_ID=
VITE_AUTH_MOCK_USERNAME=
VITE_AUTH_MOCK_EMAIL=
VITE_AUTH_MOCK_FULL_NAME=
# Lista de roles separados por coma: user,admin,transfers
VITE_AUTH_MOCK_ROLES=
# Token ficticio que se inyectará en las cabeceras Authorization
VITE_AUTH_MOCK_TOKEN=mock-dev-token

# ─── Keycloak ─────────────────────────────────────────────────────────────────
# Producción  → .env.production  (realm escritorio-virtual, SSO web.sbseguros.co)
# Certificación → .env.staging    (realm escritorio-virtual, SSO sbs-sso.modyo.be)
# Desarrollo  → .env.local        (o VITE_AUTH_MOCK_ENABLED=true para saltear Keycloak)
VITE_KEYCLOAK_URL=
VITE_KEYCLOAK_REALM=escritorio-virtual
VITE_KEYCLOAK_CLIENT_ID=SIPA-NEW
VITE_KEYCLOAK_LOGOUT_REDIRECT_URI=

# ─── Stratio ─────────────────────────────────────────────────────────────────────────
VITE_STRATIO_USER=              # Producción: sbs | Desarrollo/Cert: test
VITE_STRATIO_PASSWORD=          # Producción: credencial real | Desarrollo/Cert: 123456

# ─── Usuario de prueba (SOLO development y certification) ────────────────────
VITE_DEV_DATUSER_USER=          # Nombre completo del usuario de prueba
VITE_DEV_DATUSER_EMAIL=         # Email del usuario de prueba

# ─── APIs de Backend ──────────────────────────────────────────────────────────
# Cada clave corresponde a un microservicio backend.
# Los MFEs consumen estas URLs via createHttpClient(API.accounts) — ver shared-http.

VITE_API_CORE_URL=              # Core bancario: autenticación, usuario, permisos
VITE_API_ACCOUNTS_URL=          # Servicio de cuentas y saldos
VITE_API_TRANSFERS_URL=         # Servicio de transferencias
VITE_API_NOTIFICATIONS_URL=     # Servicio de notificaciones / alertas

# APIs heredadas SipaNew (compartidas por todos los MFEs)
VITE_API_INTEGRATION_URL=       # api-int: servicios de integración principal
VITE_API_MODYO_URL=             # Portal de integración Modyo
VITE_API_DICTIONARIES_URL=      # api-biz: diccionarios de negocio
VITE_API_STRATIO_AUTH_URL=      # api-auth: autenticación Stratio
VITE_API_REPORTS_URL=           # api-rpt: reportes
VITE_API_DAAS_DICTIONARY_URL=   # api-dict: diccionario DAAS
VITE_API_FILE_PROCESSING_URL=   # sbs-api-fileProcessing: procesamiento de archivos
VITE_API_SIPA_URL=              # api-sipa: servicio SIPA
VITE_API_WEB_URL=               # api-web: API web
VITE_API_CERTIFIER_URL=         # sbs-api-certifier (principal)
VITE_API_CERTIFIER_SBS_URL=     # sbs-api-certifier (variante SBS — puede diferir en cert)

# ─── URLs de los MFEs remotos (Module Federation) ────────────────────────────
# En desarrollo apuntan a localhost. En producción al CDN.

VITE_MFE_DASHBOARD_URL=
VITE_MFE_ACCOUNTS_URL=
VITE_MFE_TRANSFERS_URL=
VITE_MFE_LEGACY_URL=
VITE_MFE_LEGACY_BASE_URL=       # Base URL para el iframe del legacy

# ─── Configuración global de HTTP ─────────────────────────────────────────────
VITE_HTTP_TIMEOUT_MS=15000      # Timeout en milisegundos para todas las llamadas
