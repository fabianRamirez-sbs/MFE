{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "npmScope": "sipabanca",
  "affected": {
    "defaultBase": "main"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"],
        "parallel": 4
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true,
      "configurations": {
        "development": {
          "mode": "development"
        },
        "development-remote": {
          "mode": "development-remote"
        },
        "certification": {
          "mode": "certification"
        },
        "production": {
          "mode": "production",
          "defaultConfiguration": true
        }
      }
    },
    "serve": {
      "configurations": {
        "development": {
          "mode": "development"
        },
        "development-remote": {
          "mode": "development-remote"
        },
        "certification": {
          "mode": "certification"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "inputs": ["default", "^production", "{workspaceRoot}/vitest.config.base.ts"],
      "cache": true
    },
    "lint": {
      "inputs": ["default", "{workspaceRoot}/.eslintrc.json"],
      "cache": true
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/tsconfig.base.json"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.spec.vue",
      "!{projectRoot}/src/test-setup.ts"
    ]
  },
  "generators": {
    "@nx/js:library": {
      "bundler": "vite",
      "unitTestRunner": "vitest"
    }
  },
  "plugins": [
    {
      "plugin": "@nx/vite/plugin",
      "options": {
        "buildTargetName": "build",
        "testTargetName": "test",
        "serveTargetName": "serve",
        "previewTargetName": "preview"
      }
    }
  ]
}
