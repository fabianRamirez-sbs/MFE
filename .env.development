# =============================================================================
# DESARROLLO LOCAL
# Ejecutar con: nx serve <app>   (Vite usa --mode=development por defecto)
# =============================================================================

VITE_APP_ENV=development
VITE_APP_VERSION=0.0.1-local

# ─── Autenticación Mock ────────────────────────────────────────────────────────
# Cambiar a true para trabajar sin levantar Keycloak
VITE_AUTH_MOCK_ENABLED=true
VITE_AUTH_MOCK_USER_ID=dev-001
VITE_AUTH_MOCK_USERNAME=dev.user
VITE_AUTH_MOCK_EMAIL=dev@sipabanca.com
VITE_AUTH_MOCK_FULL_NAME=Developer Local
VITE_AUTH_MOCK_ROLES=user,admin
VITE_AUTH_MOCK_TOKEN=mock-dev-token-local

# Stratio — credenciales para generación de tokens (STRATIO_USER / STRATIO_PASSWORD)
VITE_STRATIO_USER=test
VITE_STRATIO_PASSWORD=123456

# Usuario de prueba para datos precargados (DEVELOP_DATUSER_*)
VITE_DEV_DATUSER_USER=Fabian Ramirez Alba
VITE_DEV_DATUSER_EMAIL=fabian.ramirez@sbseguros.co

# Keycloak local (Docker o instancia compartida de dev)
VITE_KEYCLOAK_URL=http://localhost:8080/auth
VITE_KEYCLOAK_REALM=sipabanca
VITE_KEYCLOAK_CLIENT_ID=shell-spa

# APIs locales / mocks
VITE_API_CORE_URL=http://localhost:8090/api
VITE_API_ACCOUNTS_URL=http://localhost:8091/api
VITE_API_TRANSFERS_URL=http://localhost:8092/api
VITE_API_NOTIFICATIONS_URL=http://localhost:8093/api

# APIs heredadas SipaNew — local (dev-local.env.js)
# Para apuntar a los servidores remotos de dev usa: nx serve <app> --configuration=development-remote
VITE_API_INTEGRATION_URL=http://localhost:8090
VITE_API_MODYO_URL=https://sbs-integracion.modyo.be
VITE_API_DICTIONARIES_URL=http://localhost:8091
VITE_API_STRATIO_AUTH_URL=http://localhost:8092
VITE_API_REPORTS_URL=http://localhost:8090
VITE_API_DAAS_DICTIONARY_URL=http://localhost:8094
VITE_API_FILE_PROCESSING_URL=https://devsyli.sbseguros.co/sbs-api-fileProcessing
VITE_API_SIPA_URL=http://localhost:8095
VITE_API_WEB_URL=http://localhost:8096
VITE_API_CERTIFIER_URL=http://localhost:8097
VITE_API_CERTIFIER_SBS_URL=http://sbs-api-certifier-pre.sbseguros.tech

# MFEs en localhost (cada MFE corre en su propio puerto)
# Shell = 3001 | Dashboard = 3002 | Accounts = 3003 | Transfers = 3004 | Legacy = 3005
VITE_MFE_DASHBOARD_URL=http://localhost:3002/assets/remoteEntry.js
VITE_MFE_ACCOUNTS_URL=http://localhost:3003/assets/remoteEntry.js
VITE_MFE_TRANSFERS_URL=http://localhost:3004/assets/remoteEntry.js
VITE_MFE_LEGACY_URL=http://localhost:3005/assets/remoteEntry.js
VITE_MFE_LEGACY_BASE_URL=http://localhost:3005

VITE_HTTP_TIMEOUT_MS=30000
